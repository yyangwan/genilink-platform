{
  "version": 1,
  "composition_id": "root",
  "format": {
    "language": "zh-CN",
    "aspect_ratio": "16:10",
    "width": 1280,
    "height": 800,
    "fps": 30,
    "duration_seconds": 5.6,
    "safe_zones": {
      "top_px": 34,
      "bottom_px": 40,
      "right_px": 48
    },
    "override_reason": "Landing page product-card videos use a horizontal 16:10 container, not vertical social placement."
  },
  "compiler_policy": {
    "llm_may_choose_templates": false,
    "llm_may_fill_slots": true,
    "llm_may_invent_svg_geometry": false,
    "llm_may_invent_motion_primitives": false,
    "requires_browser_text_measurement": true,
    "requires_snapshot_validation": true
  },
  "approved_contracts": {
    "vector_templates_file": "VECTOR_TEMPLATES.json",
    "motion_primitives_file": "MOTION_PRIMITIVES.json"
  },
  "scenes": [
    {
      "id": "landing-product-loop",
      "template_id": "product_workflow_loop",
      "role": "product proof loop",
      "time": {
        "start": 0,
        "end": 5.6,
        "readable_hold_start": 3.4,
        "readable_hold_end": 4.85
      },
      "content_slots": {
        "title": "module-specific Chinese title",
        "support": "none",
        "proof": "metric, metric label, bars, generated cards",
        "data": "module-specific metric",
        "icon": "status dot, cursor dot, route path",
        "cta": "none"
      },
      "layout_contract": {
        "intent": "split command-to-product proof frame",
        "image_ratio": "16:10",
        "text_axis": "left axis",
        "textRect": { "x": 58, "y": 122, "w": 398, "h": 430 },
        "subjectRect": { "x": 486, "y": 114, "w": 742, "h": 512 },
        "proofRect": { "x": 58, "y": 580, "w": 1030, "h": 172 },
        "quiet_zone": "left dark field and lower proof overlay",
        "safeBottomY": 760,
        "title_tier": "main",
        "motion_bounds": "title remains in textRect; scan and proof overlays stay inside subject/proof rects",
        "vertical_center_tolerance_px": 26
      },
      "support_assets": {
        "decision": "mixed",
        "roles": ["product fragment", "motion accent", "semantic glyph", "texture"],
        "count": 6,
        "source": "existing screenshots plus code-generated components",
        "local_paths": [
          "assets/images/website-analysis.png",
          "assets/images/visibility-audit.png",
          "assets/images/audit-reports.png",
          "assets/images/content-insights.png",
          "assets/images/competitor-analysis.png"
        ],
        "style_lock": "Black cinematic base, teal/purple/gold proof accents, glass command/proof surfaces.",
        "safe_zones": "No text or proof block may leave the 1280x800 canvas. Proof overlays stay above y=760.",
        "motion_purpose": "Show user input causing scan, route, and generated proof state.",
        "anchoring_contract": "Route path starts at command card and ends at product frame; scan rail is attached to the screenshot.",
        "entrance_exit_timing": "Input 1.0s, product reveal 1.1s, scan 1.42s, route 1.78s, proof 2.42s, loop cover 5.04s.",
        "deletion_trigger": "Delete any accent that does not explain input-to-output generation."
      },
      "visual_components": [
        {
          "component_id": "command_card",
          "required_for_product_promo": true,
          "role": "User action surface.",
          "source": "code-generated",
          "content_slots": ["domain", "Analyze", "workflow steps"],
          "icon_or_mark": "prompt dots and step dots",
          "connector_anchor": "route starts from the command card edge",
          "motion_interaction": "URL reveal and Analyze press",
          "safe_zones": "Inside x=58..456 y=250..474",
          "deletion_trigger": "Cannot delete; it proves the user operation."
        },
        {
          "component_id": "product_frame",
          "required_for_product_promo": true,
          "role": "Real product screenshot proof.",
          "source": "existing screenshot",
          "content_slots": ["image", "browser chrome"],
          "icon_or_mark": "real screen badge",
          "connector_anchor": "route ends on product frame",
          "motion_interaction": "perspective reveal and scan pass",
          "safe_zones": "Inside x=486..1228 y=114..626",
          "deletion_trigger": "Cannot delete; it is the main product proof."
        },
        {
          "component_id": "proof_layer",
          "required_for_product_promo": true,
          "role": "Generated result surface.",
          "source": "code-generated",
          "content_slots": ["metric", "bars", "chips", "cards"],
          "icon_or_mark": "score ring and proof strip",
          "connector_anchor": "generated after scan rail",
          "motion_interaction": "metric card, bars, and cards assemble from zero",
          "safe_zones": "Inside y=580..752",
          "deletion_trigger": "Delete only if product frame itself carries equivalent generated proof."
        }
      ],
      "primitive_chain": [
        {
          "primitive_id": "maskReveal",
          "target": ".title, .urlValue",
          "selection_reason": "The viewer should see information being disclosed rather than faded in."
        },
        {
          "primitive_id": "pathDraw",
          "target": ".routePath",
          "selection_reason": "The route visually connects user input to the product surface."
        }
      ],
      "snapshot_tests": [
        {
          "id": "action-hero",
          "at": 1.7,
          "assertions": ["command_visible", "product_frame_arriving", "no_text_overflow"]
        },
        {
          "id": "generation-midpoint",
          "at": 2.85,
          "assertions": ["scan_visible", "route_visible", "not_blank"]
        },
        {
          "id": "proof-lock",
          "at": 4.05,
          "assertions": ["metric_visible", "cards_visible", "bars_generated"]
        }
      ]
    }
  ],
  "batch_inputs": {
    "content_family": "product workflow loops",
    "replaceable_fields": [
      "slug",
      "image",
      "label",
      "title",
      "domain",
      "metric",
      "metricLabel",
      "step1",
      "step2",
      "step3",
      "chip1",
      "chip2",
      "chip3",
      "card1",
      "card2",
      "card3"
    ],
    "non_replaceable_fields": ["template_id", "layout_contract", "support_assets", "primitive_chain"]
  }
}
