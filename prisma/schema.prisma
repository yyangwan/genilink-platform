generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Identity ────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid()) @db.Text
  email               String?  @unique @db.Text
  passwordHash        String?  @db.Text
  name                String   @db.Text
  phone               String?  @unique @db.Text
  image               String?  @db.Text
  wechatOpenid        String?  @unique @db.Text
  wechatUnionid       String?  @unique @db.Text
  onboardingCompleted Boolean  @default(false)
  onboardingStep      String   @default("welcome") @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships   WorkspaceMember[]
  accounts      Account[]
  paymentOrders PaymentOrder[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid()) @db.Text
  userId            String  @db.Text
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String  @db.Text
  provider          String  @db.Text
  providerAccountId String  @db.Text
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.Text
  scope             String? @db.Text
  id_token          String? @db.Text

  @@unique([provider, providerAccountId])
}

model WechatLoginSession {
  id        String   @id @default(cuid()) @db.Text
  scene     String   @unique @db.Text
  status    String   @default("pending") @db.Text
  openid    String?  @db.Text
  userId    String?  @db.Text
  token     String?  @unique @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Multi-tenancy ──────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid()) @db.Text
  name      String   @db.Text
  industry  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  projects      Project[]
  brands        Brand[]
  invites       WorkspaceInvite[]
  paymentOrders PaymentOrder[]
  subscriptions Subscription[]
}

model WorkspaceMember {
  id          String    @id @default(cuid()) @db.Text
  workspaceId String    @db.Text
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @db.Text
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member") @db.Text
  joinedAt    DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid()) @db.Text
  workspaceId String    @db.Text
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid()) @db.Text
  email       String    @db.Text
  role        String    @default("member") @db.Text
  invitedBy   String    @db.Text
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

// ─── Projects & Resources ───────────────────────────────────────────

model Project {
  id          String    @id @default(cuid()) @db.Text
  name        String    @db.Text
  url               String?   @db.Text
  industry          String?   @db.Text
  productName       String?   @db.Text
  productKeywords   String[]  @default([])
  productDescription String?  @db.Text
  productUrl        String?   @db.Text
  workspaceId       String    @db.Text
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectBrands ProjectBrand[]

  @@unique([workspaceId, name])
}

// ─── Brands ────────────────────────────────────────────────────────

model Brand {
  id           String    @id @default(cuid()) @db.Text
  name         String    @db.Text
  aliases      String[]  @default([])
  isCompetitor Boolean   @default(false)
  logo         String?   @db.Text
  website      String?   @db.Text
  description  String?   @db.Text
  remoteIds    Json?     // { visibility: { projectId: remoteBrandId } }
  workspaceId  String    @db.Text
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deletedAt    DateTime? // soft delete — NULL = active
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Note: partial unique index (active names only) is created via raw SQL migration:
  // CREATE UNIQUE INDEX brand_active_name_uniq ON "Brand" ("workspaceId", name) WHERE "deletedAt" IS NULL

  projectBrands ProjectBrand[]
}

model ProjectBrand {
  id        String   @id @default(cuid()) @db.Text
  projectId String   @db.Text
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brandId   String   @db.Text
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, brandId])
  @@index([brandId])
  @@index([projectId])
}

// ─── Billing ────────────────────────────────────────────────────────

model BillingPlan {
  id             String   @id @default(cuid()) @db.Text
  key            String   @unique @db.Text
  module         String   @db.Text
  billingCycle   String   @db.Text
  name           String   @db.Text
  description    String?  @db.Text
  priceCents     Int
  currency       String   @default("CNY") @db.Text
  provider       String   @db.Text
  providerPriceId String? @unique @db.Text
  checkoutUrl    String?  @db.Text
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders PaymentOrder[]
  subscriptions Subscription[]
}

model PaymentOrder {
  id                   String    @id @default(cuid()) @db.Text
  userId               String    @db.Text
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId          String    @db.Text
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  billingPlanId        String    @db.Text
  billingPlan          BillingPlan @relation(fields: [billingPlanId], references: [id])
  module               String    @db.Text
  billingCycle         String    @db.Text
  provider             String    @db.Text
  providerSessionId    String?   @unique @db.Text
  providerCustomerId   String?   @db.Text
  providerSubscriptionId String? @unique @db.Text
  status               String    @db.Text
  amountCents          Int
  currency             String    @default("CNY") @db.Text
  checkoutUrl          String?   @db.Text
  successUrl           String?   @db.Text
  cancelUrl            String?   @db.Text
  metadata             Json?
  paidAt               DateTime?
  expiredAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  subscription Subscription?
  events       PaymentEvent[]

  @@index([userId, workspaceId, module, status])
  @@index([provider, providerSessionId])
}

model PaymentEvent {
  id                 String    @id @default(cuid()) @db.Text
  provider           String    @db.Text
  providerEventId    String    @unique @db.Text
  eventType          String    @db.Text
  status             String    @db.Text
  signatureVerified  Boolean   @default(false)
  payload            Json
  paymentOrderId     String?   @db.Text
  paymentOrder       PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  processedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([provider, eventType])
  @@index([paymentOrderId])
}

model Subscription {
  id                 String    @id @default(cuid()) @db.Text
  userId             String    @db.Text
  user               User      @relation(fields: [userId], references: [id])
  workspaceId        String    @db.Text
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  module             String    @db.Text
  status             String    @db.Text
  billingCycle       String    @db.Text
  billingPlanId      String?   @db.Text
  billingPlan        BillingPlan? @relation(fields: [billingPlanId], references: [id])
  provider           String?   @db.Text
  providerCustomerId String?   @db.Text
  providerSubscriptionId String? @unique @db.Text
  paymentOrderId     String?   @unique @db.Text
  paymentOrder       PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEnd           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([userId, workspaceId, module])
}
