# Database — PostgreSQL with connection pooling
DATABASE_URL="postgresql://user:password@localhost:5432/genilink?connection_limit=15&pool_timeout=10"

# Auth (NextAuth v5)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# WeChat MP (服务号) for QR code login
WECHAT_MP_APPID=""
WECHAT_MP_SECRET=""
WECHAT_MP_TOKEN=""

# Federation service URLs
VISIBILITY_SERVICE_URL="https://genilink.cn/visibility"
CONTENT_SERVICE_URL="http://127.0.0.1:4003"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Billing / Stripe
BILLING_CURRENCY="CNY"
BILLING_VISIBILITY_MONTHLY_CENTS="1"
BILLING_VISIBILITY_YEARLY_CENTS="1"
BILLING_CONTENT_MONTHLY_CENTS="1"
BILLING_CONTENT_YEARLY_CENTS="1"

# Billing / WeChat Pay
WECHATPAY_APP_ID=""
WECHATPAY_MCH_ID=""
WECHATPAY_MCH_SERIAL_NO=""
WECHATPAY_MCH_PRIVATE_KEY=""
WECHATPAY_PLATFORM_CERT_PEM=""
WECHATPAY_API_V3_KEY=""
WECHATPAY_NOTIFY_URL="https://genilink.cn/api/billing/webhooks/wechatpay"

# Billing / Alipay
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_NOTIFY_URL="https://genilink.cn/api/billing/webhooks/alipay"
ALIPAY_GATEWAY_URL="https://openapi.alipay.com/gateway.do"
